# Supabase - Kendi değerlerinizle doldurun
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Mobil (Expo) ---
# KBS UI: false/eksik = personel KBS sekmesi + admin KBS menüleri gizli. true = göster.
# EXPO_PUBLIC_KBS_UI_ENABLED=true
#
# KBS: lib/kbsApi → Supabase Edge `ops-proxy` → dış KBS API (mobil asla KBS URL’si tutmaz).
#
# --- Supabase Edge (Dashboard → Edge Functions → Secrets) ---
# KBS_GATEWAY_URL=https://<ops>.up.railway.app   (veya Hetzner: http://IP:4000)
# KBS_GATEWAY_TOKEN=<Edge ile dış API aynı gizli değer; istek başlığı x-kbs-gateway-token>
# (Eski isim yalnızca geriye dönük: OPS_VPS_URL)
#
# --- Dış KBS API: railway-service/ (Hetzner veya Railway) — tam liste deploy/HETZNER.md veya deploy/RAILWAY.md ---
#
# --- Hetzner VPS örneği ---
# KBS_GATEWAY_TOKEN=<Supabase secret ile aynı>
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# GATEWAY_BASE_URL=  (aynı VPS’te kbs-gateway ise http://127.0.0.1:4001 veya ayrı IP)
# GATEWAY_SHARED_SECRET=
# KBS_CREDENTIAL_SECRET=
# PORT=4000
#
# --- kbs-gateway (Hetzner’de ikinci süreç veya ayrı port) ---
# OFFICIAL_PROVIDER_MODE=http
# OFFICIAL_PROVIDER_BASE_URL=https://vatandas.jandarma.gov.tr/.../SrvShsYtkTml.svc

# Web origin (QR'larda kullanılan domain). Varsayılan: https://valoria.app
# EXPO_PUBLIC_APP_URL=https://valoriahotel-el4r.vercel.app

# Sözleşme onay sayfası URL’si. Boş bırakırsanız Supabase sayfası kullanılır.
# Temiz URL için (valoria.app/sozlesme): valoria.app’te docs/valoria-app-sozlesme-page.html’i /sozlesme path’ine koyun, sonra:
# EXPO_PUBLIC_PUBLIC_CONTRACT_URL=https://valoriahotel-el4r.vercel.app/guest/sign-one

# Publishable key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Access token (giriş / bağlantı)
SUPABASE_ACCESS_TOKEN=your-access-token

# Konum bildirimi (geofence) – otel koordinatları
# EXPO_PUBLIC_HOTEL_LAT=41.0082
# EXPO_PUBLIC_HOTEL_LON=28.9784

# Mapbox (harita) – sadece pk. (public) token; sk. sadece sunucu tarafında
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ...
