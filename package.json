{
  "name": "valoria-hotel",
  "version": "2.2.5",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-railway-or-dev.js",
    "start:dev": "expo start --dev-client --scheme exp+valoria-hotel",
    "start:dev:lan": "node scripts/dev-host.js",
    "start:dev:clear": "expo start --dev-client --scheme exp+valoria-hotel --clear",
    "start:dev:tunnel": "expo start --dev-client --tunnel --scheme exp+valoria-hotel",
    "start:go": "expo start --go --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "npm --prefix railway-service ci && npm --prefix railway-service run build",
    "vercel-build": "expo export -p web",
    "lint": "expo lint",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev": "eas build --profile development --platform all",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod:android": "eas build --profile production --platform android",
    "build:prod:ios": "eas build --profile production --platform ios",
    "submit:dev:ios": "eas submit --profile development --platform ios --latest",
    "submit:dev:android": "eas submit --profile development --platform android --latest",
    "submit:dev": "eas submit --profile development --platform all --latest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.99.0",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.0",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-text-extractor": "^2.0.0",
    "i18next": "^24.0.0",
    "mrz": "^5.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^15.0.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^4.6.3",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-vlc-media-player": "^1.0.98",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-text-extractor"
        ]
      }
    }
  },
  "private": true
}
