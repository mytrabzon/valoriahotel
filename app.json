{
  "expo": {
    "name": "valoriahotel1",
    "slug": "valoria-hotel",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "valoria-hotel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a365d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.valoria.hotel",
      "buildNumber": "2",
      "newArchEnabled": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Sözleşme onayı için QR kod okutmanız gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Profil ve belge yükleme için galeri erişimi.",
        "NSLocationWhenInUseUsageDescription": "Otele yaklaştığınızda check-in bildirimi göstermek için konum kullanılır.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Otel bölgesine girdiğinizde otomatik hoş geldiniz bildirimi için konum kullanılır.",
        "NSFaceIDUsageDescription": "Sözleşme onayında kimlik doğrulama için Face ID kullanılır.",
        "NFCReaderUsageDescription": "Dijital anahtar ile kapıyı açmak için NFC kullanılır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8B0000"
      },
      "package": "com.valoria.hotel",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.NFC",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Stok barkodu okutmak için kamera gerekir.",
          "barcodeScannerEnabled": true
        }
      ],
      "expo-location",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a365d"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Dijital anahtar ile kapıyı açmak için NFC gerekir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a365d",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Valoria"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b6913ae8-bafd-4899-96bc-ae995a4bcec1"
      }
    },
    "owner": "valoriahotel"
  }
}
