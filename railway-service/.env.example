PORT=4000
APP_ENV=local
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# İç KBS HTTP gateway (genelde aynı VPS’te farklı port, örn. 4001)
GATEWAY_BASE_URL=http://127.0.0.1:4001
GATEWAY_SHARED_SECRET=change-me-please-change-me

# Encryption key used to encrypt/decrypt ops.hotel_kbs_credentials.*_encrypted
KBS_CREDENTIAL_SECRET=change-me-please-change-me

# Supabase Edge ops-proxy ile aynı (üretimde zorunlu önerilir); boşsa başlık kontrolü yapılmaz
KBS_GATEWAY_TOKEN=

